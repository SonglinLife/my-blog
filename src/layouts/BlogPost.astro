---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { readingTime?: number };

const { title, description, pubDate, updatedDate, heroImage, tags, readingTime } = Astro.props;
const displayTags = (tags || []).filter(t => t !== 'release');
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<div class="prose">
					<div class="article-header">
						<a href="/" class="back">&larr; Back</a>
						<h1>{title}</h1>
						<div class="meta">
							<FormattedDate date={pubDate} />
							{readingTime && (
								<>
									<span class="dot">&middot;</span>
									<span class="reading-time">{readingTime} min read</span>
								</>
							)}
						</div>
						{updatedDate && (
							<div class="updated">
								Updated on <FormattedDate date={updatedDate} />
							</div>
						)}
						{displayTags.length > 0 && (
							<div class="article-tags">
								{displayTags.map(tag => (
									<a href={`/tags/${tag}/`} class="tag">{tag}</a>
								))}
							</div>
						)}
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 780px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 0 1em 2em;
	}
	.hero-image {
		width: 100%;
		margin-bottom: 2em;
	}
	.hero-image img {
		display: block;
		width: 100%;
		border-radius: 12px;
		box-shadow: var(--box-shadow);
	}
	.prose {
		max-width: 100%;
		color: var(--text);
		line-height: 1.8;
	}
	.article-header {
		margin-bottom: 2em;
		padding-bottom: 1.5em;
		border-bottom: 1px solid var(--border);
	}
	.back {
		font-size: 0.85rem;
		color: var(--text-secondary);
		text-decoration: none;
	}
	.back:hover { color: var(--accent); }
	.article-header h1 {
		margin: 0.5em 0 0.3em;
		font-size: 2.2em;
		line-height: 1.25;
	}
	.meta {
		display: flex;
		align-items: center;
		gap: 0.4em;
		color: var(--text-secondary);
		font-size: 0.9rem;
	}
	.dot { opacity: 0.5; }
	.updated {
		font-style: italic;
		font-size: 0.85rem;
		color: var(--text-secondary);
		margin-top: 0.3em;
	}
	.article-tags {
		display: flex;
		gap: 0.5em;
		flex-wrap: wrap;
		margin-top: 0.75em;
	}
	@media (max-width: 720px) {
		.article-header h1 { font-size: 1.75em; }
	}
</style>
