---
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} F3D Life. All rights reserved.</p>
	<p class="powered-by">Powered by <a href="https://astro.build" target="_blank">Astro</a> &amp; <a href="https://pages.cloudflare.com" target="_blank">Cloudflare Pages</a></p>
</footer>
<style>
	footer {
		padding: 2em 1em 3em;
		color: var(--text-secondary);
		text-align: center;
		font-size: 0.85rem;
		border-top: 1px solid var(--border);
		max-width: 780px;
		margin: 0 auto;
	}
	footer p { margin: 0.25em 0; }
	.powered-by a {
		color: var(--text-secondary);
		text-decoration: underline;
	}
	.powered-by a:hover {
		color: var(--accent);
	}
</style>
