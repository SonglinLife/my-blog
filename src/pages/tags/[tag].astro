---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getPublishedPosts } from '../../lib/posts';
import { getReadingTime } from '../../lib/reading-time';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const tags = new Set<string>();
	posts.forEach(post => {
		post.data.tags.filter(t => t !== 'release').forEach(t => tags.add(t));
	});
	return [...tags].map(tag => ({
		params: { tag },
		props: {
			tag,
			posts: posts.filter(p => p.data.tags.includes(tag)),
		},
	}));
}

const { tag, posts } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${tag} - ${SITE_TITLE}`} description={`Posts tagged "${tag}"`} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<a href="/tags/" class="back">&larr; All Tags</a>
				<h1><span class="label">Tag:</span> {tag}</h1>
				<p class="count">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>
			</div>

			<ul class="post-list">
				{posts.map((post) => {
					const readingTime = getReadingTime(post.body || '');
					return (
						<li>
							<a href={`/blog/${post.id}/`}>
								<div class="post-meta">
									<FormattedDate date={post.data.pubDate} />
									<span class="dot">&middot;</span>
									<span class="reading-time">{readingTime} min read</span>
								</div>
								<h3 class="post-title">{post.data.title}</h3>
								<p class="post-desc">{post.data.description}</p>
							</a>
						</li>
					);
				})}
			</ul>
		</main>
		<Footer />

		<style>
			.page-header {
				margin-bottom: 2em;
			}
			.back {
				font-size: 0.85rem;
				color: var(--text-secondary);
			}
			.back:hover { color: var(--accent); }
			h1 {
				margin: 0.5em 0 0.2em;
				font-size: 2em;
			}
			.label {
				color: var(--text-secondary);
				font-weight: 400;
			}
			.count {
				color: var(--text-secondary);
				font-size: 0.9rem;
				margin: 0;
			}
			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-list li {
				border-bottom: 1px solid var(--border);
			}
			.post-list li:last-child { border-bottom: none; }
			.post-list a {
				display: block;
				padding: 1.25em 0;
				text-decoration: none;
			}
			.post-list a:hover .post-title { color: var(--accent); }
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.4em;
				font-size: 0.85rem;
				color: var(--text-secondary);
				margin-bottom: 0.3em;
			}
			.dot { opacity: 0.5; }
			.post-title {
				margin: 0 0 0.3em;
				color: rgb(var(--black));
				font-size: 1.25rem;
				transition: color 0.2s;
			}
			.post-desc {
				margin: 0;
				color: var(--text-secondary);
				font-size: 0.9rem;
			}
		</style>
	</body>
</html>
